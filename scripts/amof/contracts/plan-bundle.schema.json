{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amof.dev/contracts/plan-bundle.schema.json",
  "title": "PlanBundle",
  "description": "Canonical proposal-only planning contract shared by conversational intake and planning surfaces before approval and execution.",
  "type": "object",
  "required": [
    "result_kind",
    "contract_version",
    "objective",
    "repo_scope",
    "files_to_inspect",
    "proposed_steps",
    "risks",
    "validation_plan",
    "execution_prompt_for_director",
    "requires_user_approval",
    "execution_allowed"
  ],
  "properties": {
    "result_kind": {
      "type": "string",
      "const": "plan_bundle"
    },
    "contract_version": {
      "type": "string",
      "const": "plan-bundle-v1"
    },
    "ticket_id": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "proposed_ticket_id": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "repo_scope": {
      "type": "string",
      "minLength": 1
    },
    "files_to_inspect": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "proposed_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "execution_prompt_for_director": {
      "type": "string",
      "minLength": 1
    },
    "requires_user_approval": {
      "type": "boolean",
      "const": true
    },
    "execution_allowed": {
      "type": "boolean",
      "const": false
    }
  },
  "anyOf": [
    {
      "required": ["ticket_id"]
    },
    {
      "required": ["proposed_ticket_id"]
    }
  ],
  "additionalProperties": false
}

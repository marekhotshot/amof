{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amof.dev/contracts/studio-run-reference.schema.json",
  "title": "Studio Run Reference",
  "description": "Canonical Studio Session child run reference stored in runs.json. The idempotent attachment identity is studio_session_id + run_id. Secrets, provider credentials, and raw auth material are forbidden.",
  "type": "object",
  "propertyNames": {
    "not": {
      "pattern": "(^|_|-)(secret|token|password|credential|credentials|api_key|apikey|auth_header|authorization)(_|-|$)"
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "session_id",
    "studio_session_id",
    "surface",
    "mode",
    "status",
    "events_path",
    "session_path",
    "output_path",
    "attached_at"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_run_id": {
      "type": ["string", "null"],
      "minLength": 1,
      "description": "Optional future alias for run_id when child run surfaces expose a separate canonical agent_run_id."
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "studio_session_id": {
      "type": "string",
      "pattern": "^studio-[0-9]{8}-[0-9]{6}(?:-[0-9]{2})?$"
    },
    "surface": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": ["string", "null"]
    },
    "status": {
      "type": ["string", "null"]
    },
    "events_path": {
      "type": "string",
      "minLength": 1
    },
    "session_path": {
      "type": "string",
      "minLength": 1
    },
    "output_path": {
      "type": ["string", "null"]
    },
    "attached_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}

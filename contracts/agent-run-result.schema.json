{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amof.dev/contracts/agent-run-result.schema.json",
  "title": "Agent Run Result",
  "description": "Canonical governed result contract for AMOF agent plan-execute runs.",
  "type": "object",
  "propertyNames": {
    "not": {
      "pattern": "(^|_|-)(secret|token|password|credential|credentials|api_key|apikey|auth_header|authorization)(_|-|$)"
    }
  },
  "required": [
    "result_kind",
    "contract_version",
    "schema_version",
    "status",
    "session_id",
    "exit_code",
    "stop_reason",
    "final_text",
    "plan_path",
    "checkpoint_path",
    "event_log_path",
    "journal_path",
    "budget_summary"
  ],
  "properties": {
    "result_kind": {
      "type": "string",
      "const": "agent_run_result"
    },
    "contract_version": {
      "type": "string",
      "const": "agent-run-v1"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "status": {
      "type": "string",
      "enum": ["completed", "failed", "blocked"]
    },
    "session_id": {
      "type": "string"
    },
    "exit_code": {
      "oneOf": [
        {
          "type": "integer"
        },
        {
          "type": "string",
          "const": "unknown"
        }
      ]
    },
    "studio_session_id": {
      "type": ["string", "null"],
      "description": "Optional Studio Session parent correlation for runs launched under Studio.",
      "pattern": "^studio-[0-9]{8}-[0-9]{6}(?:-[0-9]{2})?$"
    },
    "runner_id": {
      "type": ["string", "null"],
      "description": "Optional explicit runner identity used for execution."
    },
    "backend": {
      "type": ["string", "null"],
      "description": "Optional execution backend type, for example hermes_opensandbox."
    },
    "requested_provider": {
      "type": ["string", "null"]
    },
    "effective_provider": {
      "type": ["string", "null"]
    },
    "requested_model": {
      "type": ["string", "null"]
    },
    "effective_model": {
      "type": ["string", "null"]
    },
    "transport": {
      "type": ["string", "null"]
    },
    "fallback_used": {
      "type": ["boolean", "null"]
    },
    "stop_reason": {
      "type": "string",
      "minLength": 1
    },
    "final_text": {
      "type": "string",
      "description": "AMOF-authored runtime summary. Agent-observed task findings belong in task_findings and must not override runtime envelope fields.",
      "minLength": 1
    },
    "task_findings": {
      "type": ["string", "null"],
      "description": "Agent-observed task findings captured from the runner output. This field is not authoritative for AMOF runtime envelope metadata."
    },
    "plan_path": {
      "type": ["string", "null"]
    },
    "checkpoint_path": {
      "type": ["string", "null"]
    },
    "event_log_path": {
      "type": ["string", "null"]
    },
    "journal_path": {
      "type": ["string", "null"]
    },
    "runtime_log_path": {
      "type": ["string", "null"]
    },
    "result_path": {
      "type": ["string", "null"]
    },
    "runtime_log_unavailable_reason": {
      "type": ["string", "null"]
    },
    "started_at": {
      "type": ["string", "null"]
    },
    "completed_at": {
      "type": ["string", "null"]
    },
    "failure_classification": {
      "type": ["string", "null"]
    },
    "failure": {
      "type": ["object", "null"],
      "properties": {
        "failure_phase": { "type": ["string", "null"] },
        "failure_class": { "type": ["string", "null"] },
        "failure_type": { "type": ["string", "null"] },
        "failure_reason": { "type": ["string", "null"] },
        "retry_eligible": { "type": ["boolean", "null"] },
        "safe_next_action": { "type": ["string", "null"] },
        "evidence_ref": { "type": ["string", "null"] },
        "raw_error_excerpt": { "type": ["string", "null"] },
        "missing_tool": { "type": ["string", "null"] },
        "required_by": { "type": ["string", "null"] },
        "required_for": { "type": ["string", "null"] },
        "failing_tool_id": { "type": ["string", "null"] },
        "failing_tool_name": { "type": ["string", "null"] },
        "failing_tool_call_index": { "type": ["integer", "null"] },
        "tool_failure_class": { "type": ["string", "null"] },
        "tool_failure_summary": { "type": ["string", "null"] },
        "tool_failure_required": { "type": ["boolean", "null"] },
        "tool_failure_evidence_ref": { "type": ["string", "null"] },
        "required_or_optional": { "type": ["string", "null"] },
        "subtask_id": { "type": ["string", "null"] },
        "available_alternatives": {
          "type": "array",
          "items": { "type": "string" }
        },
        "runner_id": { "type": ["string", "null"] },
        "tool_inventory_ref": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "changed_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_summary": {
      "type": "object",
      "additionalProperties": true
    },
    "write_scope_proposal": {
      "type": ["object", "null"],
      "required": [
        "target_id",
        "base_sha",
        "allowed_roots",
        "denied_roots",
        "reason",
        "expected_checks",
        "docs_only",
        "source_mutation"
      ],
      "properties": {
        "target_id": {
          "type": "string",
          "minLength": 1
        },
        "base_sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "allowed_roots": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "denied_roots": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "expected_checks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "docs_only": {
          "type": "boolean"
        },
        "source_mutation": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "proposal_missing_reason": {
      "type": ["string", "null"]
    },
    "evidence_previews": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "title", "kind", "preview_text", "raw_text"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "preview_text": { "type": "string" },
          "raw_text": { "type": "string" },
          "load_error": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "approved_capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "effective_capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "object",
      "additionalProperties": true
    },
    "budget_summary": {
      "type": "object",
      "required": ["limit", "spent", "remaining"],
      "propertyNames": {
        "not": {
          "pattern": "(^|_|-)(secret|token|password|credential|credentials|api_key|apikey|auth_header|authorization)(_|-|$)"
        }
      },
      "properties": {
        "limit": {
          "type": ["number", "null"]
        },
        "spent": {
          "type": "number"
        },
        "remaining": {
          "type": ["number", "null"]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}

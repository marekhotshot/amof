{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amof.dev/contracts/bootstrap-sha256-manifest.schema.json",
  "title": "Bootstrap SHA256 Manifest",
  "description": "SHA256 manifest for a governed workstation bootstrap evidence bundle. The manifest may exclude itself to avoid self-referential hashing.",
  "type": "object",
  "required": [
    "result_kind",
    "contract_version",
    "generated_at",
    "hash_algorithm",
    "bundle_directory",
    "artifact_count",
    "artifacts",
    "excluded_artifacts"
  ],
  "properties": {
    "result_kind": {
      "type": "string",
      "const": "amof_bootstrap_sha256_manifest"
    },
    "contract_version": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "hash_algorithm": {
      "type": "string",
      "const": "sha256"
    },
    "bundle_directory": {
      "type": "string",
      "minLength": 1
    },
    "artifact_count": {
      "type": "integer",
      "minimum": 0
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/hashedArtifact"
      }
    },
    "excluded_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "hashedArtifact": {
      "type": "object",
      "required": [
        "label",
        "path",
        "sha256",
        "bytes"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amof.dev/contracts/studio-event.schema.json",
  "title": "Studio Event",
  "description": "Canonical Studio Session event object stored one-per-line in events.jsonl. Event ids are append-only monotonic sequence markers within a Studio Session. Secrets, provider credentials, and raw auth material are forbidden.",
  "type": "object",
  "propertyNames": {
    "not": {
      "pattern": "(^|_|-)(secret|token|password|credential|credentials|api_key|apikey|auth_header|authorization)(_|-|$)"
    }
  },
  "required": [
    "event_id",
    "studio_session_id",
    "timestamp",
    "event_type"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^studio-[0-9]{8}-[0-9]{6}(?:-[0-9]{2})?:[0-9]{4}$"
    },
    "studio_session_id": {
      "type": "string",
      "pattern": "^studio-[0-9]{8}-[0-9]{6}(?:-[0-9]{2})?$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "studio_session_created",
        "studio_checkpoint_added",
        "studio_session_ended",
        "run.attached",
        "studio_run_attached"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["active", "ended"]
    },
    "checkpoint_id": {
      "type": "string",
      "pattern": "^studio-[0-9]{8}-[0-9]{6}(?:-[0-9]{2})?-checkpoint-[0-9]{4}$"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "surface": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": ["string", "null"]
    },
    "events_path": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "studio_session_created"
          }
        }
      },
      "then": {
        "required": ["status"]
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "studio_checkpoint_added"
          }
        }
      },
      "then": {
        "required": ["checkpoint_id", "summary", "status"]
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "enum": ["run.attached", "studio_run_attached"]
          }
        }
      },
      "then": {
        "required": ["run_id", "session_id", "surface", "events_path"]
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "studio_session_ended"
          }
        }
      },
      "then": {
        "required": ["status"]
      }
    }
  ],
  "additionalProperties": false
}

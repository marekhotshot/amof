# Environment files (contain secrets)
.env
*.env.local

# Generated context
context/

# Synced repositories
repos/

# Git worktrees (each workspace gets its own isolated directory)
worktrees/

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
scripts/amof.egg-info/

# IDE
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Node (if any)
node_modules/

# Terraform (providers and local state)
.terraform/
*.tfstate
!*.tfstate.lock.info

# Logs
*.log

tmp/
_tmp/

# Workspace files (generated dynamically by amof)
*.code-workspace

# AMOF workspace — commit config, state, rules, and agent runs
# Only ignore ephemeral/cache files inside .amof/
.amof/runs/
.amof/vector_store/
.amof/cache/
.amof/release-environments/

kubeconfig

# Kubeconfigs (contain cluster credentials)
kubeconfigs/

# AMOF index cache (generated)
.amof/index/

# AMOF runtime droppings (cleared by clean-start slice 8;
# regenerated by the running control plane / mobile build)
.amof/server.pid
.amof/.last-mobile-tag
.amof/locks/
.amof/queue/
.amof/structured-logs/
.amof/mcp-operations/

# Nested worktree repo sets (managed by amof, not tracked as submodules).
# Broadened from the historical `dev/` subset by clean-start slice 8 so
# all ticket worktrees stay out of git.
.amof-worktrees/

# Journal pack artifacts
journal-pack-*.tar.gz
journal-pack-*/

# Local recovery artifacts and ephemeral test outputs
backups/ultra-plan-3/
test-results/

# Runtime/protocol artifact residue in the canonical operator checkout
.amof-tmp/
_lanes/
env
ecosystems/*/audit/*-promote-main-*.json
